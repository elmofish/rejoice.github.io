<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width,initial-scale=1" />
	<title>Rejoice — Home</title>
	<style>
		:root{
			--p1: #9C30CC;
			--p2: #6B31CC;
			--p3: #CC31C4;
			--p4: #3831CC;
			--p5: #CC3167;
			--bg: linear-gradient(135deg,var(--p1),var(--p2));
			--glass: rgba(255,255,255,0.06);
			--card: rgba(255,255,255,0.03);
			--accent: var(--p3);
			--text: #f6f6fb;
		}
		*{box-sizing:border-box}
		html,body{height:100%}
		body{
			margin:0;font-family:Inter,ui-sans-serif,system-ui,Segoe UI,Roboto,"Helvetica Neue",Arial;
			background: radial-gradient(1200px 600px at 10% 10%, rgba(156,48,204,0.12), transparent),
									radial-gradient(1000px 500px at 90% 90%, rgba(56,49,204,0.12), transparent),
									var(--bg);
			color:var(--text);
			-webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;
			min-height:100vh;display:flex;flex-direction:column;
		}
		header{display:flex;align-items:center;justify-content:space-between;padding:28px 48px}
		.brand{display:flex;gap:14px;align-items:center}
		.logo{width:52px;height:52px;border-radius:12px;background:linear-gradient(135deg,var(--p4),var(--p3));display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--text);box-shadow:0 6px 20px rgba(0,0,0,0.18)}
		.logo .content-bar{position:absolute;width:44px;height:6px;border-radius:6px;top:6px;background:linear-gradient(90deg,var(--p1),var(--p3));box-shadow:0 4px 14px rgba(156,48,204,0.2)}
		nav a{color:rgba(246,246,251,0.9);text-decoration:none;margin-left:22px;font-weight:600}
		.hero{display:grid;grid-template-columns:1fr 420px;gap:40px;align-items:center;padding:36px 48px 72px}
		.hero-card{background:linear-gradient(180deg,rgba(255,255,255,0.03),rgba(255,255,255,0.02));padding:36px;border-radius:18px;box-shadow:0 10px 30px rgba(12,8,38,0.45)}
		h1{font-size:48px;margin:0 0 14px;line-height:1.02;letter-spacing:-0.5px}
		p.lead{margin:0 0 22px;color:rgba(246,246,251,0.86);font-size:18px}
		.cta{display:flex;gap:12px}
		.btn{padding:12px 18px;border-radius:12px;border:0;cursor:pointer;font-weight:700}
		.btn-primary{background:linear-gradient(90deg,var(--p1),var(--p3));color:#fff;box-shadow:0 8px 30px rgba(156,48,204,0.28)}
		.btn-ghost{background:transparent;border:1px solid rgba(255,255,255,0.12);color:var(--text)}
		.features{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:22px}
		.feature{background:var(--card);padding:18px;border-radius:12px}
		.feature h3{margin:0 0 8px;font-size:16px}
		.panel-right{display:flex;flex-direction:column;gap:16px}
		.stat{background:linear-gradient(90deg,var(--p2),var(--p4));padding:18px;border-radius:12px;color:#fff;text-align:center;font-weight:700}
		footer{margin-top:auto;padding:28px 48px;color:rgba(246,246,251,0.7);display:flex;justify-content:space-between;align-items:center}
		@media (max-width:900px){
			.hero{grid-template-columns:1fr;}
			.features{grid-template-columns:1fr}
			nav{display:none}
			header{padding:18px}
			.hero{padding:18px}
		}
	</style>
</head>
<body>
	<header>
		<div class="brand">
			<div class="logo">R</div>
			<div>
				<div style="font-weight:800;letter-spacing:0.6px">Rejoice</div>
				<div style="font-size:12px;color:rgba(246,246,251,0.7)">Celebrate better moments</div>
			</div>
		</div>
		<nav>
			<a href="#">Home</a>
			<a href="#features">Features</a>
			<a href="#pricing">Pricing</a>
			<a href="#contact">Contact</a>
		</nav>
	</header>

	<main class="hero">
		<section class="hero-card">
			<h1>Make every moment worth rejoicing</h1>
			<p class="lead">Rejoice helps you plan, share, and relive your favorite memories with beautiful tools and effortless collaboration.</p>
			<div class="cta">
				<button class="btn btn-primary">Get Started — It's Free</button>
				<button class="btn btn-ghost">Learn More</button>
			</div>

			<div class="features" id="features">
				<div class="feature">
					<h3>Beautiful Templates</h3>
					<p style="margin:0;color:rgba(246,246,251,0.75);font-size:14px">Ready-made themes to celebrate any occasion.</p>
				</div>
				<div class="feature">
					<h3>Collaborative Albums</h3>
					<p style="margin:0;color:rgba(246,246,251,0.75);font-size:14px">Invite friends and build memories together.</p>
				</div>
				<div class="feature">
					<h3>Secure & Private</h3>
					<p style="margin:0;color:rgba(246,246,251,0.75);font-size:14px">Your moments stay yours — encrypted & safe.</p>
				</div>
			</div>
		</section>

		<aside class="panel-right">
			<div class="stat">+12K Moments Shared</div>
			<div class="hero-card" style="padding:18px">
				<h3 style="margin-top:0">Upcoming features</h3>
				<ul style="margin:0;padding-left:18px;color:rgba(246,246,251,0.78)">
					<li>Live collaborative editing</li>
					<li>Animated story reels</li>
					<li>One-click event pages</li>
				</ul>
			</div>
			<div style="border-radius:12px;padding:14px;background:linear-gradient(90deg,var(--p5),var(--p3));color:#fff;text-align:center">Join our beta</div>
		</aside>
	</main>

	<footer>
		<div>© Rejoice — Celebrate life</div>
		<div style="display:flex;gap:16px">
			<a href="#" style="color:rgba(246,246,251,0.7);text-decoration:none">Privacy</a>
			<a href="#" style="color:rgba(246,246,251,0.7);text-decoration:none">Terms</a>
		</div>
	</footer>
</body>
</html>

